# AI Provider: "claude" (default) or "cohere"
AI_PROVIDER=claude

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cohere API
COHERE_API_KEY=your_cohere_api_key_here

# Neon Postgres (with pgvector)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Python Bio-Service URL (local dev: http://localhost:8001)
BIO_SERVICE_URL=http://localhost:8001

# Optional: PubMed API key for literature search
PUBMED_API_KEY=

# ── Auth (iron-session) ──────────────────────────────────────
# Must be at least 32 chars. Required once password auth is enabled.
SESSION_SECRET=replace-with-a-random-string-at-least-32-characters

# Preview / local auth (disabled in production).
# When true, /login renders a signin/signup/reset form backed by
# email+password, and /api/auth/{dev-signup,signin-password,reset-password}
# are live. Leave unset in production.
NEXT_PUBLIC_ENABLE_TEST_LOGIN=true

# App URL used in password-reset links (optional; defaults to request origin)
NEXT_PUBLIC_APP_URL=http://localhost:3009
