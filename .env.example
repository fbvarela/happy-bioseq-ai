# AI Provider: "claude" (default) or "cohere"
AI_PROVIDER=claude

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Cohere API
COHERE_API_KEY=your_cohere_api_key_here

# Neon Postgres (with pgvector)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Python Bio-Service URL (local dev: http://localhost:8001)
BIO_SERVICE_URL=http://localhost:8001

# Optional: PubMed API key for literature search
PUBMED_API_KEY=
